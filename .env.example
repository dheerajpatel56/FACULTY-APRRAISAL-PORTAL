# ─────────────────────────────────────────────────────────────
# Root .env for docker-compose.prod.yml (${VAR} interpolation).
# Copy to `.env` and fill real values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Postgres
DB_PASSWORD=change-me-strong-db-password

# Auth (generate long random strings, min 32 chars)
JWT_SECRET=change-me-jwt-secret-min-32-chars
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=change-me-refresh-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS — public origin(s) of the deployed frontend. REQUIRED.
# Comma-separate multiple. Must match how users reach the site.
#   e.g. https://appraisal.vnrvjiet.in   or   http://YOUR_SERVER_IP
FRONTEND_URL=https://appraisal.example.edu

# Email (Gmail SMTP example). Code reads SMTP_PASS (app password, not account pw).
EMAIL_DISABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=VNRVJIET Faculty Portal <your-email@gmail.com>

# Grafana admin password (observability stack)
GRAFANA_PASSWORD=change-me-grafana-admin
